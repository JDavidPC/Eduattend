# .env.example
# Application
JWT_SECRET=change-this-secret

# Attendance service
ATTENDANCE_DATABASE_URL=postgresql+psycopg2://attendance_user:attendance_password@postgres_attendance:5432/attendance_db

# Auth service
AUTH_DATABASE_URL=postgresql+psycopg2://auth_user:auth_password@postgres_auth:5432/auth_db
REDIS_URL=

# User service
USER_DATABASE_URL=postgresql+psycopg2://users_user:users_password@postgres_users:5432/user_db

# Notification service
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_DATABASE_URL=postgresql+psycopg2://notifications_user:notifications_password@postgres_notifications:5432/notifications_db
